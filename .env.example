# ─────────────────────────────────────────────────────────────
# n8n Platform Intelligence Agent — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# .env is gitignored and should NEVER be committed to git.

# ── n8n connection ────────────────────────────────────────────
N8N_BASE_URL=http://localhost:5678

# Generate in n8n UI: Bottom-left icon → Settings → API → Create API Key
N8N_API_KEY=your_n8n_api_key_here

# ── LLM Provider ─────────────────────────────────────────────
# Option A: NVIDIA NIM (free tier available at build.nvidia.com)
NVIDIA_API_KEY=nvapi-your-key-here

# Option B: Anthropic Claude (uncomment and set if using Claude directly)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── LLM Model Configuration (optional — defaults shown) ──────
# LLM_MODEL=meta/llama-3.3-70b-instruct
# LLM_API_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions

# ── FastAPI Server ────────────────────────────────────────────
API_HOST=localhost
API_PORT=8000
